#!/usr/bin/env bash

set -euo pipefail

# ------------------------------------------------------------------------------
# Title: Install My Unix Programs (2025 Edition)
# Description: Unified setup script for macOS and Debian/Ubuntu AI/ML environments.
# Author: Diego Oliveira
# ------------------------------------------------------------------------------

# === Global setup =============================================================
timestamp=$(date +"%Y%m%d%H%M%S")
OS=$(uname -s)
ARCH=$(uname -m)
INSTALL_ML_LIBS=true
INSTALL_FONTS=true
DRY_RUN=false

usage() {
  cat <<'EOF'
Usage: install_my_programs_unix [options]

Options:
  --dry-run       Print planned actions without changing the system
  --skip-ml       Skip installing AI/ML Python packages
  --skip-fonts    Skip installing fonts
  -h, --help      Show this help message
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-ml)
        INSTALL_ML_LIBS=false
        ;;
      --dry-run)
        DRY_RUN=true
        ;;
      --skip-fonts)
        INSTALL_FONTS=false
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1" >&2
        usage
        exit 1
        ;;
    esac
    shift
  done
}

# ------------------------------------------------------------------------------
# 🧩 Utility functions
# ------------------------------------------------------------------------------

backup_file() {
  local file="$1"
  if [[ -f "$file" ]]; then
    local backup="${file}.${timestamp}.bak"
    run_cmd cp "$file" "$backup"
    echo "📦 Backed up $file → $backup"
  fi
}

run_cmd() {
  if [[ "$DRY_RUN" == "true" ]]; then
    printf '[dry-run] %s\n' "$*"
    return 0
  fi
  "$@"
}

run_shell() {
  if [[ "$DRY_RUN" == "true" ]]; then
    printf '[dry-run] %s\n' "$1"
    return 0
  fi
  eval "$1"
}

install_pkg() {
  local pkg="$1"
  if [[ "$OS" == "Darwin" ]]; then
    if [[ "$DRY_RUN" == "true" ]]; then
      run_cmd brew install "$pkg"
    else
      brew list "$pkg" &>/dev/null || brew install "$pkg"
    fi
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      run_cmd sudo apt install -y "$pkg"
    else
      dpkg -s "$pkg" &>/dev/null || sudo apt install -y "$pkg"
    fi
  fi
}

install_optional_brew_formula() {
  local formula="$1"
  local label="${2:-$1}"

  if [[ "$DRY_RUN" == "true" ]]; then
    run_cmd brew install "$formula"
    return
  fi

  if ! brew info "$formula" >/dev/null 2>&1; then
    echo "ℹ️ ${label} unavailable in current Homebrew taps; skipping"
    return
  fi

  if brew list "$formula" &>/dev/null; then
    echo "✅ ${label} already installed"
    return
  fi

  brew install "$formula"
  echo "✅ Installed ${label}"
}

install_apt_first_available() {
  local label="$1"
  shift

  if [[ "$DRY_RUN" == "true" ]]; then
    run_cmd sudo apt install -y "$1"
    return
  fi

  local pkg
  for pkg in "$@"; do
    if dpkg -s "$pkg" >/dev/null 2>&1; then
      echo "✅ ${label} already installed (${pkg})"
      return
    fi

    if sudo apt install -y "$pkg" >/dev/null 2>&1; then
      echo "✅ Installed ${label} (${pkg})"
      return
    fi
  done

  echo "ℹ️ ${label} unavailable in configured apt repositories; skipping"
}

install_with_fallback() {
  local label="$1"
  local apt_pkg="$2"
  local cargo_pkg="${3:-}"
  local brew_formula="${4:-}"

  if [[ "$OS" == "Darwin" ]]; then
    if [[ -n "$brew_formula" ]]; then
      install_optional_brew_formula "$brew_formula" "$label"
    fi
    return
  fi

  if [[ "$DRY_RUN" == "true" ]]; then
    run_cmd sudo apt install -y "$apt_pkg"
    return
  fi

  if dpkg -s "$apt_pkg" >/dev/null 2>&1; then
    echo "✅ ${label} already installed (${apt_pkg})"
    return
  fi

  if sudo apt install -y "$apt_pkg" >/dev/null 2>&1; then
    echo "✅ Installed ${label} (${apt_pkg})"
    return
  fi

  if [[ -n "$cargo_pkg" ]] && command -v cargo >/dev/null 2>&1; then
    if [[ "$DRY_RUN" == "true" ]]; then
      run_cmd cargo install "$cargo_pkg" --locked
    else
      cargo install "$cargo_pkg" --locked || true
    fi
    return
  fi

  if [[ -n "$brew_formula" ]] && command -v brew >/dev/null 2>&1; then
    install_optional_brew_formula "$brew_formula" "$label"
    return
  fi

  echo "ℹ️ ${label} fallback unavailable; skipping"
}

has_linux_gpu() {
  if command -v nvidia-smi >/dev/null 2>&1; then
    return 0
  fi

  if [[ -e "/dev/dri" ]]; then
    return 0
  fi

  return 1
}

install_brew() {
  if ! command -v brew &>/dev/null; then
    echo "🍺 Installing Homebrew..."
    if [[ "$DRY_RUN" == "true" ]]; then
      printf '[dry-run] /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"\n'
    else
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
  fi
}

install_ohmyzsh() {
  if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
    echo "💫 Installing Oh-My-Zsh..."
    if [[ "$DRY_RUN" == "true" ]]; then
      printf '[dry-run] sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended\n'
    else
      sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    fi
  fi
}

clone_if_missing() {
  local repo="$1"
  local dest="$2"
  if [[ ! -d "$dest" ]]; then
    echo "🔗 Cloning $repo → $dest"
    run_cmd git clone --depth=1 "$repo" "$dest"
  fi
}

safe_copy() {
  local src="$1"
  local dest="$2"
  if [[ -f "$src" ]]; then
    run_cmd mkdir -p "$(dirname "$dest")"
    run_cmd cp -f "$src" "$dest"
    echo "📝 Installed $src → $dest"
  fi
}

install_local_bin_script() {
  local src="$1"
  local dest_dir="$HOME/.local/bin"
  local dest
  dest="$dest_dir/$(basename "$src")"
  if [[ -f "$src" ]]; then
    run_cmd mkdir -p "$dest_dir"
    run_cmd cp -f "$src" "$dest"
    run_cmd chmod +x "$dest"
    echo "🧰 Installed $(basename "$src") → $dest"
  fi
}

# ------------------------------------------------------------------------------
# 🧰 1. System base setup
# ------------------------------------------------------------------------------

setup_system() {
  echo "⚙️ Setting up system base packages..."
  if [[ "$OS" == "Darwin" ]]; then
    install_brew
    run_cmd brew update
    run_cmd brew upgrade
    run_cmd brew install git curl wget neovim tmux htop btop bottom tree jq fzf zoxide ripgrep bat fd gh cmake python uv direnv atuin pre-commit parallel coreutils
  else
    run_cmd sudo apt update -y
    run_cmd sudo apt upgrade -y
    run_cmd sudo apt install -y curl wget git neovim tmux zsh htop btop tree jq fzf zoxide ripgrep bat fd-find cmake python3 python3-pip python3-venv python3-dev direnv pre-commit parallel
  fi
}

setup_monitoring() {
  echo "📈 Configuring monitoring stack..."

  if [[ "$OS" == "Darwin" ]]; then
    if [[ "$ARCH" == "arm64" ]]; then
      install_optional_brew_formula asitop "asitop"
    fi

    echo "ℹ️ nvtop skipped on macOS"
    return
  fi

  if has_linux_gpu; then
    if apt-cache show nvtop >/dev/null 2>&1; then
      sudo apt install -y nvtop
      echo "✅ nvtop installed (Linux GPU detected)"
    else
      echo "ℹ️ nvtop package not available in configured apt repositories"
    fi
  else
    echo "ℹ️ No GPU device detected; nvtop skipped"
  fi
}

install_productivity_cli_stack() {
  echo "🧰 Installing advanced productivity CLI tools..."

  if [[ "$OS" == "Darwin" ]]; then
    install_optional_brew_formula lazygit
    install_optional_brew_formula glow
    install_optional_brew_formula hyperfine
    install_optional_brew_formula yq
    install_optional_brew_formula shellcheck
    install_optional_brew_formula shfmt
    install_optional_brew_formula git-delta "git-delta (delta)"
    install_optional_brew_formula tealdeer "tealdeer (tldr)"
    install_optional_brew_formula gawk
    install_optional_brew_formula entr
    install_optional_brew_formula parallel "gnu parallel"
    install_optional_brew_formula dua-cli "dua-cli (dua)"
    install_optional_brew_formula dust
    install_optional_brew_formula procs
    install_optional_brew_formula xh
    install_optional_brew_formula doggo
    install_optional_brew_formula watchexec
    install_optional_brew_formula kubectl
    install_optional_brew_formula k9s
    install_optional_brew_formula trivy
    install_optional_brew_formula zellij
    return
  fi

  install_apt_first_available lazygit lazygit
  install_apt_first_available glow glow
  install_apt_first_available hyperfine hyperfine
  install_apt_first_available yq yq
  install_apt_first_available shellcheck shellcheck
  install_apt_first_available shfmt shfmt
  install_with_fallback "git-delta (delta)" git-delta git-delta git-delta
  install_with_fallback "tealdeer (tldr)" tealdeer tealdeer tealdeer
  install_apt_first_available gawk gawk
  install_apt_first_available entr entr
  install_apt_first_available "gnu parallel" parallel
  install_apt_first_available "dua-cli (dua)" dua-cli
  install_apt_first_available dust du-dust dust
  install_apt_first_available procs procs
  install_apt_first_available xh xh
  install_apt_first_available doggo doggo
  install_apt_first_available watchexec watchexec
  install_apt_first_available kubectl kubectl kubernetes-client
  install_apt_first_available k9s k9s
  install_apt_first_available trivy trivy
  install_with_fallback zellij zellij zellij zellij
}

# ------------------------------------------------------------------------------
# 🧠 2. Python setup
# ------------------------------------------------------------------------------

setup_python() {
  echo "🐍 Installing Python packages..."
  local pip_args=()
  run_cmd python3 -m ensurepip --upgrade || true

  if [[ "$OS" == "Darwin" ]]; then
    run_cmd python3 -m pip install -U pip wheel setuptools
  else
    pip_args+=(--break-system-packages)
    echo "ℹ️ Using distro-managed pip tooling on Linux (PEP 668); skipping pip/wheel/setuptools upgrade"
  fi

  if [[ -f "./requirements.txt" ]]; then
    run_cmd python3 -m pip install "${pip_args[@]}" -r ./requirements.txt
  fi
}

# ------------------------------------------------------------------------------
# 💫 3. Shell setup (Zsh, Oh-My-Zsh, Starship)
# ------------------------------------------------------------------------------

setup_shell() {
  echo "💫 Configuring shell..."
  install_ohmyzsh

  if [[ "$OS" == "Darwin" ]]; then
    run_cmd brew install starship atuin
  else
    run_shell "curl -sS https://starship.rs/install.sh | sh -s -- -y"
    if ! command -v atuin &>/dev/null; then
      if command -v apt-get &>/dev/null; then
        sudo apt-get install -y atuin || true
      fi
    fi
    if ! command -v atuin &>/dev/null; then
      if command -v cargo &>/dev/null; then
        run_cmd cargo install atuin --locked || true
      else
        curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | bash || true
      fi
    fi
    if ! command -v atuin &>/dev/null; then
      if command -v cargo &>/dev/null; then
        echo "⚠️ Atuin not installed. Retry manually: cargo install atuin --locked"
      else
        echo "⚠️ Atuin not installed. Retry manually: curl --proto '=https' --tlsv1.2 -LsSf https://setup.atuin.sh | bash"
      fi
    fi
  fi

  # Backup and replace configs
  for file in "$HOME/.bashrc" "$HOME/.zshrc"; do
    backup_file "$file"
  done
  backup_file "$HOME/.config/starship.toml"

  # Copy new configs
  safe_copy "./run_commands/my_bashrc" "$HOME/.bashrc"
  safe_copy "./run_commands/my_zshrc" "$HOME/.zshrc"
  safe_copy "./run_commands/my_starship.toml" "$HOME/.config/starship.toml"

  # Source custom files if preferred style
  for shell_file in bashrc zshrc; do
    target="$HOME/.${shell_file}"
    myfile="$HOME/.my_${shell_file}"
    [[ -f "./run_commands/my_${shell_file}" ]] && run_cmd cp "./run_commands/my_${shell_file}" "$myfile"
    if ! grep -q "source ~/.my_${shell_file}" "$target" 2>/dev/null; then
      if [[ "$DRY_RUN" == "true" ]]; then
        printf '[dry-run] echo "source ~/.my_%s" >> %s\n' "$shell_file" "$target"
      else
        echo "source ~/.my_${shell_file}" >>"$target"
      fi
      echo "🪄 Added sourcing line to $target"
    fi
  done

  if [[ -f "./run_commands/secrets_shell.env.example" ]]; then
    run_cmd mkdir -p "$HOME/.config/secrets"
    if [[ ! -f "$HOME/.config/secrets/shell.env" ]]; then
      run_cmd cp -f "./run_commands/secrets_shell.env.example" "$HOME/.config/secrets/shell.env"
      run_cmd chmod 600 "$HOME/.config/secrets/shell.env"
      echo "✅ Installed $HOME/.config/secrets/shell.env (edit with your local secrets)"
    fi
  fi
}

# ------------------------------------------------------------------------------
# 🪶 4. NeoVim + Lazy.nvim
# ------------------------------------------------------------------------------

setup_neovim() {
  echo "🪶 Setting up NeoVim..."
  clone_if_missing "https://github.com/folke/lazy.nvim.git" "$HOME/.local/share/nvim/lazy/lazy.nvim"
  run_cmd mkdir -p "$HOME/.config/nvim"
  run_cmd mkdir -p "$HOME/.config/nvim/lua/utils_scripts"
  backup_file "$HOME/.config/nvim/init.lua"
  safe_copy "./run_commands/my_nvim_init.lua" "$HOME/.config/nvim/init.lua"
  for module in plugins options keymaps lsp ui; do
    safe_copy "./run_commands/nvim/lua/utils_scripts/${module}.lua" "$HOME/.config/nvim/lua/utils_scripts/${module}.lua"
  done
}

# ------------------------------------------------------------------------------
# 🧩 5. Fonts (Nerd Font / Fira Code)
# ------------------------------------------------------------------------------

setup_fonts() {
  echo "🔤 Installing fonts..."
  if [[ "$OS" == "Darwin" ]]; then
    run_cmd brew install --cask font-fira-code-nerd-font
  else
    run_cmd mkdir -p ~/.local/share/fonts
    run_cmd wget -q https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip -O /tmp/FiraCode.zip
    run_cmd unzip -o /tmp/FiraCode.zip -d ~/.local/share/fonts
    run_cmd fc-cache -fv
  fi
}

# ------------------------------------------------------------------------------
# 🧩 6. Tmux + TPM
# ------------------------------------------------------------------------------

setup_tmux() {
  echo "🧩 Installing Tmux plugin manager..."
  clone_if_missing "https://github.com/tmux-plugins/tpm" "$HOME/.tmux/plugins/tpm"
  backup_file "$HOME/.tmux.conf"
  safe_copy "./run_commands/my_tmux.conf" "$HOME/.tmux.conf"

  if command -v tmux >/dev/null 2>&1 && [[ -x "$HOME/.tmux/plugins/tpm/bin/install_plugins" ]]; then
    echo "🧩 Installing tmux plugins from ~/.tmux.conf..."
    run_cmd tmux start-server
    run_cmd tmux source-file "$HOME/.tmux.conf"
    run_cmd "$HOME/.tmux/plugins/tpm/bin/install_plugins"
  fi
}

# ------------------------------------------------------------------------------
# 🧩 7. Ghostty (macOS)
# ------------------------------------------------------------------------------

setup_ghostty() {
  if [[ "$OS" != "Darwin" ]]; then
    echo "🧩 Ghostty setup skipped on non-macOS."
    return
  fi

  echo "🧩 Installing Ghostty and config..."
  if ! brew list --cask ghostty &>/dev/null; then
    run_cmd brew install --cask ghostty
  fi
  run_cmd mkdir -p "$HOME/.config/ghostty"
  backup_file "$HOME/.config/ghostty/config"
  safe_copy "./run_commands/my_ghostty_config" "$HOME/.config/ghostty/config"
}

# ------------------------------------------------------------------------------
# 🤖 8. AI/ML libraries (optional)
# ------------------------------------------------------------------------------

install_ml_libs() {
  echo "🧠 Installing AI/ML Python packages..."
  run_cmd python3 -m pip install -U numpy pandas scikit-learn jupyterlab matplotlib seaborn \
    torch torchvision torchaudio xgboost lightgbm transformers sentence-transformers \
    openai optuna mlflow
}

# ------------------------------------------------------------------------------
# 📎 9. Local helper scripts
# ------------------------------------------------------------------------------

install_local_scripts() {
  echo "📎 Installing local helper scripts..."
  install_local_bin_script "./bootstrap_shell_secrets"
  install_local_bin_script "./br_init_project"
  install_local_bin_script "./codex_apply_config"
  install_local_bin_script "./repomix_generate"
  install_local_bin_script "./run_commands/tmux_network_bandwidth_safe"
}

# ------------------------------------------------------------------------------
# 📿 10. Beads tracker
# ------------------------------------------------------------------------------

install_br_tracker() {
  echo "📿 Installing Beads tracker (br)..."
  if command -v br &>/dev/null; then
    echo "✅ br already installed. Skipping."
    return
  fi
  if command -v bd &>/dev/null; then
    echo "ℹ️ Found legacy bd command. Keep using it until br is installed on this machine."
    return
  fi
  run_shell "curl -fsSL https://raw.githubusercontent.com/steveyegge/beads/main/scripts/install.sh | bash"
}

# ------------------------------------------------------------------------------
# 🤖 11. Codex config
# ------------------------------------------------------------------------------

install_codex_config() {
  echo "🤖 Configuring Codex..."
  run_cmd mkdir -p "$HOME/.codex"
  safe_copy "./run_commands/codex_config.toml" "$HOME/.codex/config.template.toml"
  if [[ -x "$HOME/.local/bin/codex_apply_config" ]]; then
    "$HOME/.local/bin/codex_apply_config"
  else
    echo "⚠️ codex_apply_config not installed; skipping config apply."
  fi
}

# ------------------------------------------------------------------------------
# 🚀 Run all setup steps
# ------------------------------------------------------------------------------

main() {
  parse_args "$@"
  echo "🧠 Detected OS: $OS"
  echo "🧬 Detected ARCH: $ARCH"
  setup_system
  setup_monitoring
  install_productivity_cli_stack
  install_br_tracker
  install_local_scripts
  install_codex_config
  setup_python
  setup_shell
  setup_neovim
  setup_ghostty
  if [[ "$INSTALL_FONTS" == "true" ]]; then
    setup_fonts
  else
    echo "🔤 Skipping fonts install."
  fi
  setup_tmux
  if [[ "$INSTALL_ML_LIBS" == "true" ]]; then
    install_ml_libs
  else
    echo "🧠 Skipping AI/ML Python packages."
  fi
  echo "✅ All done! Restart your terminal to apply changes."
  echo "💡 Tip: Add 'eval \"\$(starship init zsh)\"' to ~/.zshrc"
}

main "$@"
